<Window x:Class="TargMasiniWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Târg Mașini"
        Height="760" Width="1180"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#070A12">

    <Window.Resources>
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent" Color="#38BDF8"/>
        <SolidColorBrush x:Key="Accent2" Color="#A78BFA"/>
        <SolidColorBrush x:Key="Card" Color="#172033"/>
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="28" ShadowDepth="8" Opacity="0.35"/>

        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0"/>
            <GradientStop Color="#111827" Offset="0.45"/>
            <GradientStop Color="#1E1B4B" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#273449"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#38BDF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0EA5E9"/>
                                <Setter Property="Foreground" Value="#020617"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="CaretBrush" Value="#38BDF8"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          MinHeight="20"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#38BDF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputLabel" TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="Check" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6,22,6"/>
        </Style>

        <Style x:Key="Radio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6,22,6"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="22,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#020617"/>
            <Setter Property="Background" Value="#38BDF8"/>
            <Setter Property="BorderBrush" Value="#7DD3FC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7DD3FC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="22,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="#0F172A"
                                          Foreground="{TemplateBinding Foreground}"
                                          BorderBrush="#334155"
                                          BorderThickness="1"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <ContentPresenter Margin="12,0,35,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Text="▼"
                                               Foreground="#94A3B8"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0"/>
                                </Grid>
                            </ToggleButton>

                            <Popup Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#0F172A"
                                        BorderBrush="#38BDF8"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#0F172A"/>

                        <Style.Triggers>
                            <Trigger Property="Content" Value="Alb">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Negru">
                                <Setter Property="Background" Value="Black"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Gri">
                                <Setter Property="Background" Value="Gray"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Argintiu">
                                <Setter Property="Background" Value="Silver"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Roșu">
                                <Setter Property="Background" Value="Red"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Bordo">
                                <Setter Property="Background" Value="#7F1D1D"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Albastru">
                                <Setter Property="Background" Value="DodgerBlue"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Bleumarin">
                                <Setter Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Verde">
                                <Setter Property="Background" Value="Green"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Verde închis">
                                <Setter Property="Background" Value="#14532D"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Galben">
                                <Setter Property="Background" Value="Yellow"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Portocaliu">
                                <Setter Property="Background" Value="Orange"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Maro">
                                <Setter Property="Background" Value="#78350F"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Bej">
                                <Setter Property="Background" Value="#F5DEB3"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Auriu">
                                <Setter Property="Background" Value="Gold"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Mov">
                                <Setter Property="Background" Value="Purple"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Roz">
                                <Setter Property="Background" Value="HotPink"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Turcoaz">
                                <Setter Property="Background" Value="Turquoise"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Cameleon">
                                <Setter Property="Background" Value="#22C55E"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Mat">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource MainGradient}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="265"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0B1120"
                BorderBrush="#1E293B"
                BorderThickness="0,0,1,0"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="68"
                            Height="68"
                            CornerRadius="22"
                            BorderBrush="#7DD3FC"
                            BorderThickness="1"
                            Background="#0EA5E9"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,18">
                        <TextBlock Text="TT"
                                   FontSize="34"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="AutoVault"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMain}"/>

                    <TextBlock Text="Gestionarea tranzacțiilor auto"
                               FontSize="13"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,4,0,30"/>

                    <Button Name="BtnNavLista"
                            Content="Lista tranzacțiilor"
                            Click="NavLista_Click"
                            Style="{StaticResource MenuButton}"/>

                    <Button Name="BtnNavAdauga"
                            Content="Adaugă tranzacție"
                            Click="NavAdauga_Click"
                            Style="{StaticResource MenuButton}"/>

                    <Button Name="BtnNavCauta"
                            Content="Caută tranzacție"
                            Click="NavCauta_Click"
                            Style="{StaticResource MenuButton}"/>
                    <Button Name="BtnNavModifica"
                            Content="Modifică tranzacție"
                            Click="NavModifica_Click"
                            Style="{StaticResource MenuButton}"/>

                </StackPanel>

                
            </Grid>
        </Border>

        <Grid Grid.Column="1">

            <Grid Name="PaginaLista" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="30"
                        Padding="26"
                        CornerRadius="24"
                        Background="#172033"
                        BorderBrush="#334155"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Lista tranzacțiilor"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}"/>

                            <TextBlock Name="lblSubtitluLista"
                                       Text="Tranzacții auto înregistrate în sistem"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#0F172A"
                                CornerRadius="18"
                                Padding="18,12"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total:"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                                <Label Name="lblTotalTranzactii"
                                       Content="0"
                                       Foreground="#38BDF8"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="30,0,30,30">
                    <StackPanel>
                        <Button Content="Reîncarcă lista"
                                Click="BtnReincarca_Click"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"/>

                        <StackPanel Name="StackTranzactii"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Name="PaginaAdauga" Visibility="Collapsed">
                <ScrollViewer Margin="30">
                    <Border Background="#172033"
                            CornerRadius="28"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            Padding="34"
                            MaxWidth="760"
                            HorizontalAlignment="Left">

                        <StackPanel>
                            <TextBlock Text="Adaugă tranzacție"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}"/>

                            <TextBlock Text="Completează datele necesare pentru înregistrarea unei tranzacții auto."
                                       FontSize="14"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,7,0,28"/>

                            <TextBlock Text="01  Date persoane"
                                       Foreground="#38BDF8"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Label Name="lblVanzator"
                                           Content="Vânzător"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtVanzator"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Label Name="lblCumparator"
                                           Content="Cumpărător"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtCumparator"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="02  Date mașină"
                                       Foreground="#A78BFA"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Margin="0,6,0,14"/>

                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Label Name="lblFirma"
                                           Content="Producător / Firmă"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtFirma"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Label Name="lblModel"
                                           Content="Model"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtModel"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Label Name="lblAn"
                                           Content="An fabricație"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtAn"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Label Name="lblCuloare"
                                           Content="Culoare"
                                           Style="{StaticResource InputLabel}"/>
                                    <ComboBox Name="cboCuloare"
                                              Style="{StaticResource Combo}"/>
                                </StackPanel>
                            </Grid>

                            <Label Content="Tip combustibil"
                                   Style="{StaticResource InputLabel}"/>

                            <Border Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16"
                                    Margin="0,0,0,24">
                                <WrapPanel>
                                    <RadioButton Name="rbBenzina"
                                                 Content="Benzină"
                                                 GroupName="Combustibil"
                                                 IsChecked="True"
                                                 Style="{StaticResource Radio}"/>

                                    <RadioButton Name="rbDiesel"
                                                 Content="Diesel"
                                                 GroupName="Combustibil"
                                                 Style="{StaticResource Radio}"/>

                                    <RadioButton Name="rbHibrid"
                                                 Content="Hibrid"
                                                 GroupName="Combustibil"
                                                 Style="{StaticResource Radio}"/>

                                    <RadioButton Name="rbElectric"
                                                 Content="Electric"
                                                 GroupName="Combustibil"
                                                 Style="{StaticResource Radio}"/>
                                </WrapPanel>
                            </Border>

                            <Label Content="Dotări opționale"
                                   Style="{StaticResource InputLabel}"/>

                            <Border Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16"
                                    Margin="0,0,0,24">
                                <WrapPanel>
                                    <CheckBox Name="chkAer"
                                              Content="Aer condiționat"
                                              Style="{StaticResource Check}"/>
                                    <CheckBox Name="chkNav"
                                              Content="Navigație GPS"
                                              Style="{StaticResource Check}"/>
                                    <CheckBox Name="chkAuto"
                                              Content="Cutie automată"
                                              Style="{StaticResource Check}"/>
                                    <CheckBox Name="chkScaune"
                                              Content="Scaune încălzite"
                                              Style="{StaticResource Check}"/>
                                    <CheckBox Name="chkSenzori"
                                              Content="Senzori parcare"
                                              Style="{StaticResource Check}"/>
                                    <CheckBox Name="chkCamera"
                                              Content="Cameră marșarier"
                                              Style="{StaticResource Check}"/>
                                </WrapPanel>
                            </Border>

                            <TextBlock Text="03  Detalii tranzacție"
                                       Foreground="#38BDF8"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Margin="0,6,0,14"/>

                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Label Name="lblData"
                                           Content="Data tranzacției"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtData"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Label Name="lblPret"
                                           Content="Preț"
                                           Style="{StaticResource InputLabel}"/>
                                    <TextBox Name="txtPret"
                                             Style="{StaticResource Input}"/>
                                </StackPanel>
                            </Grid>

                            <Border Name="brdMesaj"
                                    Visibility="Collapsed"
                                    Padding="15"
                                    Margin="0,0,0,18"
                                    Background="#0F172A"
                                    BorderBrush="#38BDF8"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <TextBlock Name="lblMesaj"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="{StaticResource TextMain}"/>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Salvează tranzacția"
                                        Click="BtnSalveaza_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,12,0"/>

                                <Button Content="Resetează"
                                        Click="BtnAnuleaza_Click"
                                        Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <Grid Name="PaginaCauta" Visibility="Collapsed">
                <StackPanel Margin="30" MaxWidth="650">
                    <Border Background="#172033"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="28"
                            Padding="34">

                        <StackPanel>
                            <TextBlock Text="Caută tranzacție"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}"/>

                            <TextBlock Text="Căutarea se poate face după numele clientului și/sau după marca mașinii. Dacă sunt completate ambele câmpuri, se afișează doar tranzacțiile care corespund ambelor criterii."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="14"
                                       Margin="0,7,0,24"
                                       TextWrapping="Wrap"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0"
                                       Content="Numele clientului"
                                       Style="{StaticResource InputLabel}"/>
                                <Label Grid.Row="0" Grid.Column="2"
                                       Content="Marca mașinii"
                                       Style="{StaticResource InputLabel}"/>

                                <TextBox Name="txtCautaClient"
                                         Grid.Row="2"
                                         Grid.Column="0"
                                         Style="{StaticResource Input}"
                                         ToolTip="Exemplu: Popescu"/>

                                <TextBox Name="txtCautaMarca"
                                         Grid.Row="2"
                                         Grid.Column="2"
                                         Style="{StaticResource Input}"
                                         ToolTip="Exemplu: BMW, Audi, Toyota"/>

                                <Button Grid.Row="2"
                                        Grid.Column="4"
                                        Content="Caută"
                                        Click="BtnCauta_Click"
                                        Style="{StaticResource PrimaryButton}"/>
                            </Grid>

                            <Border Name="brdRezultat"
                                    Visibility="Collapsed"
                                    Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="20"
                                    Margin="0,0,0,15">
                                <StackPanel Name="stackRezultat"/>
                            </Border>

                            <Border Name="brdNegasit"
                                    Visibility="Collapsed"
                                    Background="#3B0A19"
                                    BorderBrush="#FF5370"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16">
                                <TextBlock Text="Tranzacția nu a fost găsită."
                                           Foreground="#FF5370"
                                           FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            <Grid Name="PaginaModifica" Visibility="Collapsed">
                <ScrollViewer Margin="30">
                    <Border Background="#172033" BorderBrush="#334155" BorderThickness="1" CornerRadius="28" Padding="34" MaxWidth="760" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Modifică tranzacție" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="Caută o tranzacție după model mașină sau nume cumpărător, apoi selectează din listă." FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,7,0,24"/>

                            <!-- Zona de căutare -->
                            <Label Content="Caută tranzacția de modificat" Style="{StaticResource InputLabel}"/>
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Name="txtCautaModifica" Grid.Column="0" Style="{StaticResource Input}" ToolTip="Caută după model mașină sau nume cumpărător"/>
                                <Button Grid.Column="1" Content="Caută" Click="BtnCautaTranzactiiModifica_Click" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Width="80"/>
                            </Grid>

                            <!-- Lista rezultate căutare -->
                            <Label Content="Rezultate căutare" Style="{StaticResource InputLabel}"/>
                            <ListBox Name="lstRezultateModifica" Height="140" Background="#0F172A" Foreground="White" BorderBrush="#334155" SelectionChanged="lstRezultateModifica_SelectionChanged" DisplayMemberPath="DescriereScurta" Margin="0,0,0,22"/>

                            <!-- Restul câmpurilor de editare (rămân neschimbate) -->
                            <Label Content="Vânzător" Style="{StaticResource InputLabel}"/>
                            <TextBox Name="txtVanzatorModifica" Style="{StaticResource Input}" Margin="0,0,0,22"/>

                            <Label Content="Cumpărător" Style="{StaticResource InputLabel}"/>
                            <TextBox Name="txtCumparatorModifica" Style="{StaticResource Input}" Margin="0,0,0,22"/>

                            <Label Content="Marca mașinii" Style="{StaticResource InputLabel}"/>
                            <TextBox Name="txtFirmaModifica" Style="{StaticResource Input}" Margin="0,0,0,22"/>

                            <Label Content="Model" Style="{StaticResource InputLabel}"/>
                            <TextBox Name="txtModelModifica" Style="{StaticResource Input}" Margin="0,0,0,22"/>

                            <Label Content="An fabricație" Style="{StaticResource InputLabel}"/>
                            <TextBox Name="txtAnModifica" Style="{StaticResource Input}" Margin="0,0,0,22"/>

                            <Label Content="Preț" Style="{StaticResource InputLabel}"/>
                            <TextBox Name="txtPretModifica" Style="{StaticResource Input}" Margin="0,0,0,22"/>

                            <Label Content="Data tranzacției" Style="{StaticResource InputLabel}"/>
                            <DatePicker Name="dpDataModifica" Height="42" Margin="0,0,0,22"/>

                            <Label Content="Dotări" Style="{StaticResource InputLabel}"/>
                            <ListBox Name="lstDotariModifica" Height="160" SelectionMode="Multiple" Background="#0F172A" Foreground="White" BorderBrush="#334155" Margin="0,0,0,24"/>

                            <Button Content="Actualizează tranzacția" Click="BtnActualizeaza_Click" Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>



        </Grid>
    </Grid>
</Window>